# Search providers
DDGS_ENABLED=false
SEARXNG_URL=http://localhost:8080
TAVILY_API_KEY=
FIRECRAWL_API_KEY=

# Qwen 235B served by vLLM (OpenAI-compatible)
QWEN_MODEL=Qwen/Qwen3-235B-A22B-Instruct-2507
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=dummy

# Discovery/crawl limits
MAX_RESULTS_PER_QUERY=10
MAX_DISCOVERY_ITERATIONS=3
MAX_URLS_TO_CRAWL=1000

# Offline/dry-run switches — run the full pipeline with zero network
SEARCH_MOCK=false
LLM_MOCK=false
